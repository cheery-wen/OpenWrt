# ========== 全局编译优化 ==========
CONFIG_DEVEL=y
CONFIG_USE_LLD=y
CONFIG_USE_LD_LDFLAGS=y
CONFIG_LTO=y
CONFIG_WERROR=n
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_SSTRIP=y

# ========== APK管理器｜彻底禁用OPKG ==========
CONFIG_USE_APK=y
CONFIG_USE_OPKG=n
CONFIG_APK_HTTPS=y
CONFIG_APK_USE_WOLFSSL=y

# ========== 目标架构 ==========
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ========== 启动与镜像 ==========
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y

# ========== 分区大小 ==========
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# ========== 网卡驱动 ==========
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-r8125=y
CONFIG_PACKAGE_kmod-r8156=y
CONFIG_PACKAGE_kmod-pci=y
CONFIG_PACKAGE_kmod-pci-hotplug=y

# ========== 硬件加速 ==========
CONFIG_PACKAGE_kmod-crypto-aes=y
CONFIG_PACKAGE_kmod-crypto-authenc=y

# ========== 全锥NAT ==========
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y

# ========== LuCI核心必选 ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_rpcd-mod-file=y
CONFIG_PACKAGE_rpcd-mod-luci=y
CONFIG_PACKAGE_rpcd-mod-rrdns=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

# ========== USB/磁盘/挂载 ==========
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-ehci=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_udev=y
CONFIG_PACKAGE_kmod-udev-core=y
CONFIG_PACKAGE_mount-utils=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_uuidgen=y
CONFIG_PACKAGE_nls_utf8=y
CONFIG_PACKAGE_nls_cp936=y
CONFIG_PACKAGE_hdparm=y

# ========== HTTPS + 中文 ==========
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ========== 主题 ==========
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-material=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-openwrt-2020=y

# ========== 基础常用组件 ==========
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_btrfs_progs=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_lsblk=y
CONFIG_PACKAGE_luci-app-diskman_INCLUDE_mdadm=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-cpufreq=y

# ========== 仅保留指定第三方插件 ==========
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_lucky=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y

# ========== DDNS Cloudflare ==========
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts_cloudflare.com-v4=y

# ========== IPv6 ==========
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_dnsmasq-full_dhcpv6=y

# ========== 中文翻译 ==========
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-filetransfer-zh-cn=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y

# ========== 系统工具 ==========
CONFIG_PACKAGE_ntpclient=y
CONFIG_PACKAGE_system-ntp=y
CONFIG_PACKAGE_luci-app-timecontrol=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_pingtest=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_luci-app-swap=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_ramlog=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_poweroff=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_arptables=y
CONFIG_PACKAGE_coreutils=y

# ========== 温控/微码｜官方标准包名 ==========
CONFIG_PACKAGE_intel-microcode=y
CONFIG_PACKAGE_amd64-microcode=y
CONFIG_PACKAGE_iucode-tool=y
CONFIG_PACKAGE_kmod-cpu-msr=y
CONFIG_PACKAGE_kmod-ipt-raw=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_sensorconf=y
CONFIG_PACKAGE_kmod-hwmon-coretemp=y
CONFIG_PACKAGE_kmod-hwmon-it87=y

# ========== 状态监控 ==========
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_collectd-mod-sensors=y
CONFIG_PACKAGE_collectd-mod-cpufreq=y
CONFIG_PACKAGE_collectd-mod-load=y

# ========== 实用工具 ==========
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_lscpu=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_util-linux-fstrim=y

# ========== 基础依赖 ==========
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_zoneinfo-shanghai=y

# ========== 编译精简 ==========
CONFIG_KERNEL_DEBUG=n

# ========== x86_64 低延迟内核优化 ==========
CONFIG_HZ_1000=y
CONFIG_PREEMPT=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_IRQ_BALANCE=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_KERNEL_IRQ_AFFINITY=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG_BBR=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_CAKE=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_CONNTRACK_ZONES=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_DEFAULT_IOSCHED_NONE=y
CONFIG_KERNEL_KALLSYMS=n
CONFIG_CRYPTO_TEST=n
