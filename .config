# ==================================================
# 1. Target & Image
# ==================================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ==================================================
# 2. LuCI Core
# ==================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-ssl=y

CONFIG_PACKAGE_rpcd=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y

CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y

CONFIG_LUCI_LANG_zh_Hans=y

# ==================================================
# 3. LuCI i18n
# ==================================================
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-network-zh-cn=y
CONFIG_PACKAGE_luci-i18n-system-zh-cn=y
CONFIG_PACKAGE_luci-i18n-dhcp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wireless-zh-cn=y

# ==================================================
# 4. Kernel Network
# ==================================================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_TCP_FASTOPEN=y

CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y

# ==================================================
# 5. Firewall (fw4 nft)
# ==================================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_luci-app-firewall=y

CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-conntrack=y
CONFIG_PACKAGE_kmod-nft-fib=y

# ==================================================
# 6. IPv6
# ==================================================
CONFIG_PACKAGE_dnsmasq_full=y
CONFIG_PACKAGE_odhcp6c=y

# ==================================================
# 7. Storage + Mount（挂载点已补齐）
# ==================================================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_luci-app-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_fstrim=y

CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y

CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_blkid=y

CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-hd-idle=y

# ==================================================
# 8. Disk Management
# ==================================================
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_smartmontools=y

# ==================================================
# 9. USB
# ==================================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# ==================================================
# 10. Network drivers (x86)
# ==================================================
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-r8125=y
CONFIG_PACKAGE_kmod-r8168=y

# ==================================================
# 11. Tools + Web UI
# ==================================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_chrony=y
CONFIG_PACKAGE_tcpdump=y

CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-poweroffdevice=y
CONFIG_PACKAGE_luci-app-timecontrol=y

# ==================================================
# 12. CPU Temperature + Stats
# ==================================================
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-statistics-config=y

CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-thermal=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-load=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-rrdtool=y

# ==================================================
# 13. App Filter (OAF)
# ==================================================
CONFIG_PACKAGE_oaf=y
CONFIG_PACKAGE_luci-app-oaf=y

# ==================================================
# 14. Theme
# ==================================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ==================================================
# 15. Plugins
# ==================================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-ghfu=y

# ==================================================
# 16. DDNS
# ==================================================
CONFIG_PACKAGE_ddns-scripts=y
